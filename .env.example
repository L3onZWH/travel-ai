# Travel AI Agent — 环境变量配置
# 复制本文件为 .env 并填写对应值

# ---- Anthropic (Claude) ----------------------------------------------------
# 必填：在 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=sk-ant-...

# 可选：默认 claude-opus-4-5
ANTHROPIC_MODEL=claude-opus-4-5

# 可选：自定义 API Base URL（代理/中转地址，不填则使用官方默认）
ANTHROPIC_BASE_URL=

# ---- Search ----------------------------------------------------------------
# 可选：Tavily 搜索 API Key（在 https://app.tavily.com/ 获取）
# 不填则使用 DuckDuckGo（免费，无需 key）
TAVILY_API_KEY=
